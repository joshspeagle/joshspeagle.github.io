{
  "_comment": "Redesign design tokens (single source of truth). build_tokens.py -> assets/css/tokens.css. Namespaced (--bg/--text/--violet/...) to coexist with the legacy theme-variables.css until all pages are migrated.",
  "themeVarying": {
    "bg-0":        { "dark": "#06080f", "light": "#f6f6f1" },
    "bg-1":        { "dark": "#0a0e20", "light": "#eef0f5" },
    "bg-2":        { "dark": "#0a1228", "light": "#e9ecf4" },
    "surface":     { "dark": "rgba(255,255,255,0.04)", "light": "#fffefb" },
    "surface-2":   { "dark": "rgba(255,255,255,0.06)", "light": "#f4f3ee" },
    "border":      { "dark": "rgba(255,255,255,0.08)", "light": "#e4e2d7" },
    "text":        { "dark": "#eef1fb", "light": "#14161d" },
    "text-2":      { "dark": "#aeb6d6", "light": "#46444c" },
    "text-3":      { "dark": "#8a97c2", "light": "#67645d" },
    "violet":      { "dark": "#8b7bff", "light": "#5b43d6" },
    "violet-bright": { "dark": "#a99bff", "light": "#7c5cff" },
    "cyan":        { "dark": "#34d3e0", "light": "#0e9aa8" },
    "cyan-bright": { "dark": "#5be0ee", "light": "#0e9aa8" },
    "blue":        { "dark": "#5aa9ff", "light": "#1565c0" },
    "grad":        { "dark": "linear-gradient(95deg,#a99bff,#6fd2ff)", "light": "linear-gradient(95deg,#5b43d6,#0e9aa8)" },
    "grad-text":   { "dark": "linear-gradient(95deg,#bda9ff,#7cc9ff 55%,#5be0ee)", "light": "linear-gradient(95deg,#5b43d6,#1565c0 55%,#0e9aa8)" },
    "cat-sla":     { "dark": "#8b7bff", "light": "#5b43d6" },
    "cat-ii":      { "dark": "#34d3e0", "light": "#0a7280" },
    "cat-ic":      { "dark": "#5aa9ff", "light": "#1565c0" },
    "cat-du":      { "dark": "#ffb454", "light": "#8f4d00" },
    "shadow-card": { "dark": "0 8px 30px rgba(0,0,0,0.35)", "light": "0 10px 30px rgba(40,38,28,0.10)" },
    "shadow-glow": { "dark": "0 8px 32px rgba(124,92,255,0.45)", "light": "0 8px 26px rgba(91,67,214,0.30)" }
  },
  "base": {
    "font-serif": "'Source Serif 4', Georgia, 'Times New Roman', serif",
    "font-sans": "'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
    "font-mono": "'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, Consolas, monospace",
    "font-cjk": "'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Noto Sans CJK SC', sans-serif",
    "fs-display": "clamp(3rem, 6vw, 5rem)",
    "fs-h1": "clamp(2.2rem, 4vw, 3.25rem)",
    "fs-h2": "clamp(1.6rem, 2.6vw, 2rem)",
    "fs-h3": "1.25rem",
    "fs-body": "1.0625rem",
    "fs-small": "0.9rem",
    "fs-label": "0.78rem",
    "space-1": "4px",
    "space-2": "8px",
    "space-3": "12px",
    "space-4": "16px",
    "space-5": "24px",
    "space-6": "32px",
    "space-7": "48px",
    "space-8": "64px",
    "space-9": "80px",
    "radius-sm": "8px",
    "radius-card": "14px",
    "radius-panel": "20px",
    "radius-pill": "40px",
    "maxw": "1200px"
  }
}
